---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedPosts, getPublishedTranslations } from "../lib/content";
import {
  blogPath,
  LANGUAGE_UI_LABELS,
  SITE_DESCRIPTION,
  type LanguageCode,
} from "../lib/site";

const posts = await getPublishedPosts();
const translations = await getPublishedTranslations();
const languageOrder = Object.keys(LANGUAGE_UI_LABELS) as LanguageCode[];
const translationsByPost = translations.reduce((grouped, translation) => {
  const postTranslations = grouped.get(translation.data.translationOf) ?? [];
  postTranslations.push(translation);
  grouped.set(translation.data.translationOf, postTranslations);
  return grouped;
}, new Map<string, typeof translations>());

function postLanguageUrl(slug: string, lang: LanguageCode, defaultLang: LanguageCode) {
  const base = blogPath(`${slug}/`);
  return lang === defaultLang ? base : `${base}?lang=${lang}`;
}
---

<BaseLayout description={SITE_DESCRIPTION}>
  <section class="intro">
    <p class="eyebrow">Mister Teddy</p>
    <h1>Blog</h1>
    <p>Personal writing, notes, and records.</p>
  </section>

  <section class="post-list" aria-label="Posts">
    {
      posts.length === 0 ? (
        <p class="empty">No posts yet.</p>
      ) : (
        posts.map((post) => {
          const postTranslations = (translationsByPost.get(post.data.slug) ?? []).sort(
            (a, b) =>
              languageOrder.indexOf(a.data.lang) - languageOrder.indexOf(b.data.lang),
          );
          const originalLanguage = LANGUAGE_UI_LABELS[post.data.lang];
          const languageOptions = [
            {
              code: post.data.lang,
              name: originalLanguage.name,
              role: originalLanguage.original,
            },
            ...postTranslations.map((translation) => {
              const translationLanguage = LANGUAGE_UI_LABELS[translation.data.lang];
              return {
                code: translation.data.lang,
                name: translationLanguage.name,
                role: translationLanguage.translation,
              };
            }),
          ];
          return (
            <article
              class="post-card"
              data-post-card
              data-default-language={post.data.lang}
            >
              <div class="post-card-meta">
                <p class="post-meta post-meta-date">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString("en", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </p>
                {languageOptions.length > 1 && (
                  <p class="post-meta post-meta-languages">
                    {languageOptions.map((language, index) => (
                      <>
                        {index > 0 && (
                          <span class="post-meta-separator" aria-hidden="true">
                            /
                          </span>
                        )}
                        <a
                          class="post-meta-language"
                          data-language-link={language.code}
                          href={postLanguageUrl(
                            post.data.slug,
                            language.code,
                            post.data.lang,
                          )}
                        >
                          {language.name} ({language.role})
                        </a>
                      </>
                    ))}
                  </p>
                )}
              </div>
              <h2 class="post-card-title">
                <span data-language-panel={post.data.lang}>
                  <a href={postLanguageUrl(post.data.slug, post.data.lang, post.data.lang)}>
                    {post.data.title}
                  </a>
                </span>
                {postTranslations.map((translation) => (
                  <span data-language-panel={translation.data.lang}>
                    <a
                      href={postLanguageUrl(
                        post.data.slug,
                        translation.data.lang,
                        post.data.lang,
                      )}
                    >
                      {translation.data.title}
                    </a>
                  </span>
                ))}
              </h2>
              <p class="post-card-description">
                <span data-language-panel={post.data.lang}>{post.data.description}</span>
                {postTranslations.map((translation) => (
                  <span data-language-panel={translation.data.lang}>
                    {translation.data.description}
                  </span>
                ))}
              </p>
              {post.data.tags.length > 0 && (
                <ul class="tags" aria-label="Tags">
                  {post.data.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
            </article>
          );
        })
      )
    }
  </section>

  <script is:inline>
    document.querySelectorAll("[data-post-card]").forEach((card) => {
      const defaultLanguage = card.dataset.defaultLanguage;
      if (!defaultLanguage) return;

      const languageLinks = card.querySelectorAll("[data-language-link]");
      if (languageLinks.length === 0) return;

      const previewLanguage = (language) => {
        if (language === defaultLanguage) {
          delete card.dataset.previewLanguage;
          return;
        }

        card.dataset.previewLanguage = language;
      };

      const hoverless = window.matchMedia("(hover: none)");

      languageLinks.forEach((link) => {
        // Hover/focus preview only on devices that actually hover. On touch,
        // focus fires on tap *before* click — if it pre-set the preview, the
        // click would see "already current" and fall through to navigation.
        link.addEventListener("mouseenter", () => {
          if (!hoverless.matches) previewLanguage(link.dataset.languageLink);
        });
        link.addEventListener("focus", () => {
          if (!hoverless.matches) previewLanguage(link.dataset.languageLink);
        });
        // Touch: first tap previews the language; tapping the already-previewed
        // language opens the post.
        link.addEventListener("click", (event) => {
          if (!hoverless.matches) return;
          const target = link.dataset.languageLink;
          const current = card.dataset.previewLanguage ?? defaultLanguage;
          if (target !== current) {
            event.preventDefault();
            previewLanguage(target);
          }
        });
      });

      card.addEventListener("mouseleave", () => {
        delete card.dataset.previewLanguage;
      });

      card.addEventListener("focusout", (event) => {
        if (!card.contains(event.relatedTarget)) {
          delete card.dataset.previewLanguage;
        }
      });
    });
  </script>
</BaseLayout>

---
interface Props {
  src: string;
  alt?: string;
  title?: string;
  width?: number | string;
  height?: number | string;
}

const { src, alt = "", title, width, height } = Astro.props;
---

<button
  type="button"
  class="prose-image-button"
  data-lightbox-src={src}
  aria-label={alt ? `View full image: ${alt}` : "View full image"}
>
  <img src={src} alt={alt} title={title} width={width} height={height} loading="lazy" decoding="async" />
</button>
